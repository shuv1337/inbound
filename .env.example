# =============================================================================
# Inbound — Environment Variables
# =============================================================================
# Copy to .env.production and fill in all required values.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://mail.example.com
INTERNAL_BASE_URL=http://127.0.0.1:3000
DOCS_URL=https://docs.example.com

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://inbound:changeme@postgres:5432/inbound
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Auth (Better Auth)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=generate-a-random-secret-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Contact / Notifications
# -----------------------------------------------------------------------------
SUPPORT_EMAIL=support@example.com
LEGAL_EMAIL=legal@example.com
ADMIN_EMAIL=admin@example.com
USAGE_REPORT_TO=admin@example.com

# -----------------------------------------------------------------------------
# Redis (Upstash)
# -----------------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# AWS (SES, S3, Lambda)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
S3_BUCKET_NAME=
SES_FROM_EMAIL=noreply@example.com
LAMBDA_FUNCTION_NAME=

# -----------------------------------------------------------------------------
# QStash (Upstash)
# -----------------------------------------------------------------------------
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# -----------------------------------------------------------------------------
# SDK (self-consumption)
# -----------------------------------------------------------------------------
INBOUND_API_KEY=
SERVICE_API_KEY=

# -----------------------------------------------------------------------------
# Cron / Webhooks
# -----------------------------------------------------------------------------
CRON_SECRET=generate-a-random-secret-here

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# SVIX_API_KEY=
# OPENAI_API_KEY=
# SLACK_ADMIN_WEBHOOK_URL=
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=
# GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_GITHUB_TOKEN=
# MANAGED_DOMAINS=
# GUARD_AI_MODEL=
# MAILGUN_API_KEY=
# MAILGUN_DOMAIN=
